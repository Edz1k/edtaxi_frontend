{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:passenger": "pnpm --filter @edtaxi/passenger build",
    "build:driver": "pnpm --filter @edtaxi/driver build",
    "build:web": "pnpm --filter @edtaxi/web build",
    "build:share": "pnpm --filter @edtaxi/share build",
    "dev:passenger": "pnpm --filter @edtaxi/passenger dev",
    "dev:driver": "pnpm --filter @edtaxi/driver dev",
    "dev:web": "pnpm --filter @edtaxi/web dev",
    "dev:share": "pnpm --filter @edtaxi/share dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "postinstall": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@unocss/eslint-config": "catalog:build",
    "cypress": "catalog:dev",
    "cypress-vite": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-plugin-cypress": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "lint-staged": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
